# Duke Nukem 3D: Neon Noir API Credentials Template
#
# DO NOT commit this file if you add real credentials.
# Copy this file to .env and fill in your own values:
#   cp .env.example .env
# Keep .env in .gitignore and never commit it.
#
# Obtain credentials:
# - AUDIO_* keys: Azure OpenAI portal (Cognitive Services > Text-to-Speech / Audio API)
# - FLUX_* keys: Black Forest Labs (Flux API) or Azure Deployment

# Azure OpenAI Audio API (GPT Audio 1.5 for voice generation)
AUDIO_ENDPOINT=<your-azure-audio-endpoint>
AUDIO_MODEL=gpt-audio-1.5
AUDIO_API_KEY=<your-audio-api-key>

# FLUX Image Generation API (for procedural texture synthesis)
FLUX_ENDPOINT=<your-flux-api-endpoint>
FLUX_MODEL=FLUX.2-pro
FLUX_API_KEY=<your-flux-api-key>
